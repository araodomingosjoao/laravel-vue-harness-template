{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "compilerOptions": {
        "paths": {
            "@/*": ["./resources/js/*"]
        },
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "moduleResolution": "bundler",
        "types": ["vite/client", "node"]
    },
    "include": [
        "resources/js/**/*.ts",
        "resources/js/**/*.d.ts",
        "resources/js/**/*.tsx",
        "resources/js/**/*.vue"
    ],
    "exclude": ["node_modules", "dist", "public/build"]
}
