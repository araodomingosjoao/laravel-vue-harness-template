APP_NAME="Todo List"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=todo
DB_USERNAME=todo
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173
SESSION_DOMAIN=localhost

# ─── Harness configuration ───────────────────────────
# Estas variáveis controlam o comportamento do agente.
# NUNCA exponhas ANTHROPIC_API_KEY em logs nem em PRs.

HARNESS_ENABLED=true
HARNESS_MAX_TOKENS_PER_TASK=200000
HARNESS_MAX_TOOL_CALLS_PER_TASK=80
HARNESS_MAX_DURATION_SECONDS=1800
HARNESS_MAX_PRS_PER_HOUR=5
HARNESS_REQUIRE_HUMAN_APPROVAL_PATHS="config/,app/Http/Middleware/,database/migrations/*destructive*"

ANTHROPIC_API_KEY=
