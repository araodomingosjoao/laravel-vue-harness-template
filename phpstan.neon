includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - app/
        - config/
        - database/
        - routes/
        # tests/ omitido de propósito: as closures do Pest (it()/test()) ligam
        # $this a TestCase de forma que o PHPStan lê como Pest\PendingCalls\TestCall.
        # Os testes são validados pelo Pest, não pela análise estática.

    level: 8

    # Ficheiros gerados ou de terceiros que não devemos analisar
    excludePaths:
        - bootstrap/cache/*

    # Larastan-specific: garantir que tipos de Eloquent são respeitados
    checkModelProperties: true
    checkPhpDocMissingReturn: true

    # Reportar TODO/FIXME para o agente não esquecer
    reportUnmatchedIgnoredErrors: true

    # Forçar tipagem estrita
    treatPhpDocTypesAsCertain: true

    # Nota: não precisamos de ignorar acesso a propriedades de Models —
    # o Larastan trata-as via checkModelProperties acima.
